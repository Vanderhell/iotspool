# Toolchain file for ARM Cortex-M (STM32 etc.)
set(CMAKE_SYSTEM_NAME Generic)
set(CMAKE_SYSTEM_PROCESSOR arm)

set(CMAKE_C_COMPILER   arm-none-eabi-gcc)
set(CMAKE_CXX_COMPILER arm-none-eabi-g++)
set(CMAKE_ASM_COMPILER arm-none-eabi-gcc)

set(IOTSPOOL_ARM_CPU "cortex-m4" CACHE STRING "ARM Cortex-M CPU")
set(IOTSPOOL_ARM_FPU "" CACHE STRING "Optional ARM FPU")
set(IOTSPOOL_ARM_FLOAT_ABI "" CACHE STRING "Optional ARM float ABI")
set(CMAKE_C_FLAGS_INIT "-mcpu=${IOTSPOOL_ARM_CPU} -mthumb")
if(IOTSPOOL_ARM_FPU)
    string(APPEND CMAKE_C_FLAGS_INIT " -mfpu=${IOTSPOOL_ARM_FPU}")
endif()
if(IOTSPOOL_ARM_FLOAT_ABI)
    string(APPEND CMAKE_C_FLAGS_INIT " -mfloat-abi=${IOTSPOOL_ARM_FLOAT_ABI}")
endif()
set(CMAKE_EXE_LINKER_FLAGS_INIT "--specs=nosys.specs")

set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
